{
  "version": 2,
  "builds": [
    {
      "src": "api/main_lite.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/main_lite.py",
      "headers": {
        "Access-Control-Allow-Origin": "https://market-intelligence-system-app.vercel.app",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    }
  ]
}